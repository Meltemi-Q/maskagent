{
  "name": "maskagent",
  "version": "0.4.0",
  "description": "TypeScript mission orchestration CLI with persistent state, worker/validator loops, and benchmark tooling.",
  "type": "module",
  "bin": {
    "maskagent": "dist/cli.js",
    "mission": "dist/cli.js",
    "missionctl": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "README.zh-CN.md",
    "VALIDATION.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test tests/runtime.test.mjs",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
